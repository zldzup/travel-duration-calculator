a(0xFF01,'!','全角!→半角');a(0xFF1F,'?','全角?→半角');a(0xFF04,'$','全角$→半角');a(0xFF05,'%','全角%→半角');
a(0xFF06,'&','全角&→半角');a(0xFF0A,'*','全角*→半角');a(0xFF0B,'+','全角+→半角');a(0xFF0F,'/','全角/→半角');
