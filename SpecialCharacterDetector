function uCp(){
  const raw=document.getElementById('uI').value;if(!raw)return;
  const cl=[...raw].map(ch=>{const cp=ch.codePointAt(0);if(ZW.has(cp)||cp===0xFEFF||DR.has(cp)||inR(cp,VS)||inR(cp,TG)||FL.has(cp)||cp===SH||SP.has(cp)&&cp!==0x00A0)return'';if(LA[cp])return LA[cp][0];return ch}).join('').replace(/\u00A0/g,' ').replace(/\u3000/g,' ');
  navigator.clipboard.writeText(cl).then(()=>{const b=document.querySelectorAll('#ud .bt');const t=b[b.length-1];const o=t.textContent;t.textContent='✅ 已复制';setTimeout(()=>t.textContent=o,1200)});
}
document.addEventListener('mouseover',e=>{if(e.target.classList.contains('hw')){const t=document.getElementById('uTT');t.textContent=e.target.dataset.info;t.style.display='block'}});
document.addEventListener('mousemove',e=>{const t=document.getElementById('uTT');if(t.style.display==='block'){t.style.left=(e.clientX+10)+'px';t.style.top=(e.clientY-28)+'px'}});
document.addEventListener('mouseout',e=>{if(e.target.classList.contains('hw'))document.getElementById('uTT').style.display='none'});
document.getElementById('uL').innerHTML='<div class="empty">请粘贴文本后点击检测</div>';
</script>
</div>
