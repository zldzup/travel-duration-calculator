a(0x0422,'T','西里尔Т→T');a(0x0425,'X','西里尔Х→X');a(0x0405,'S','西里尔Ѕ→S');a(0x0408,'J','西里尔Ј→J');
a(0x0391,'A','希腊Α→A');a(0x0392,'B','希腊Β→B');a(0x0395,'E','希腊Ε→E');a(0x0396,'Z','希腊Ζ→Z');
a(0x0397,'H','希腊Η→H');a(0x0399,'I','希腊Ι→I');a(0x039A,'K','希腊Κ→K');a(0x039C,'M','希腊Μ→M');
a(0x039D,'N','希腊Ν→N');a(0x039F,'O','希腊Ο→O');a(0x03A1,'P','希腊Ρ→P');a(0x03A4,'T','希腊Τ→T');
a(0x03A5,'Y','希腊Υ→Y');a(0x03A7,'X','希腊Χ→X');
a(0x03B1,'a','希腊α→a');a(0x03B5,'e','希腊ε→e');a(0x03B7,'n','希腊η→n');a(0x03B9,'i','希腊ι→i');
a(0x03BA,'k','希腊κ→k');a(0x03BC,'m','希腊μ→m');a(0x03BD,'v','希腊ν→v');a(0x03BF,'o','希腊ο→o');
a(0x03C1,'p','希腊ρ→p');a(0x03C5,'u','希腊υ→u');a(0x03C7,'x','希腊χ→x');
const MR=[[0x1D400,0x1D433],[0x1D434,0x1D467],[0x1D468,0x1D49B],[0x1D49C,0x1D4CF],[0x1D4D0,0x1D503],[0x1D504,0x1D537],[0x1D56C,0x1D59F],[0x1D5A0,0x1D5D3],[0x1D5D4,0x1D607],[0x1D608,0x1D63B],[0x1D63C,0x1D66F],[0x1D670,0x1D6A3],[0x1D7CE,0x1D7D7],[0x1D7D8,0x1D7E1],[0x1D7E2,0x1D7EB],[0x1D7EC,0x1D7F5],[0x1D7F6,0x1D7FF]];
const SU=new Set([...'⁰¹²³⁴⁵⁶⁷⁸⁹⁺⁻⁼⁽⁾ⁿ'].map(c=>c.codePointAt(0)));
const SB=new Set([...'₀₁₂₃₄₅₆₇₈₉₊₋₌₍₎'].map(c=>c.codePointAt(0)));
const JP=new Set([0x3001,0x3002,0x300A,0x300B,0x300C,0x300D,0x300E,0x300F,0x3010,0x3011,0x3014,0x3015,0x3016,0x3017]);
function inR(cp,rs){for(const[a,b]of rs)if(cp>=a&&cp<=b)return true;return false}
function isCf(cp){try{return/\p{Cf}/u.test(String.fromCodePoint(cp))}catch(e){return false}}
function cls(cp){
  if(ZW.has(cp))return{c:C1,l:'零宽/隐藏'};
  if(DR.has(cp))return{c:C4,l:'方向控制'};
  if(inR(cp,VS))return{c:C1,l:'变体选择符'};
  if(inR(cp,TG))return{c:C1,l:'标签字符'};
  if(FL.has(cp))return{c:C1,l:'填充字符'};
  if(cp===SH)return{c:C1,l:'软连字符'};
  if(SP.has(cp))return{c:C2,l:'异常空格'};
  if(LA[cp])return{c:C3,l:'易混淆'};
  if(inR(cp,MR))return{c:C3,l:'数学字母'};
  if(SU.has(cp))return{c:C3,l:'上标字符'};
  if(SB.has(cp))return{c:C3,l:'下标字符'};
  if(ST.has(cp))return{c:C4,l:'结构控制'};
  if(JP.has(cp))return{c:C5,l:'中文标点'};
  if(cp>=0xFF01&&cp<=0xFF5E&&!LA[cp])return{c:C5,l:'全角符号'};
  if(isCf(cp)&&cp>0x7F)return{c:C6,l:'格式字符'};
  if(cp<0x20&&cp!==9&&cp!==10&&cp!==13)return{c:C6,l:'控制字符'};
  if(cp===0x7F)return{c:C6,l:'DEL'};
  return null;
}
function gn(cp){
  const N={0x200B:'ZERO WIDTH SPACE',0x200C:'ZERO WIDTH NON-JOINER',0x200D:'ZERO WIDTH JOINER',0x2060:'WORD JOINER',0xFEFF:'BOM',0x00AD:'SOFT HYPHEN (软连字符)',0x200E:'LRM 左→右标记',0x200F:'RLM 右→左标记',0x202A:'LRE 左→右嵌入',0x202B:'RLE 右→左嵌入',0x202C:'PDF 方向弹出',0x202D:'LRO 左→右覆盖',0x202E:'RLO 右→左覆盖 ⚠️翻转文本!',0x2066:'LRI 左→右隔离',0x2067:'RLI 右→左隔离',0x2068:'FSI 首强隔离',0x2069:'PDI 弹出方向隔离',0x00A0:'NO-BREAK SPACE',0x1680:'OGHAM SPACE MARK',0x202F:'NARROW NO-BREAK SPACE',0x205F:'MEDIUM MATH SPACE',0x3000:'IDEOGRAPHIC SPACE 全角空格',0x2800:'BRAILLE PATTERN BLANK 盲文空格',0x2028:'LINE SEPARATOR ⚠️断行',0x2029:'PARAGRAPH SEPARATOR ⚠️断段',0xFFF9:'INTERLINEAR ANNOTATION ANCHOR',0xFFFA:'INTERLINEAR ANNOTATION SEPARATOR',0xFFFB:'INTERLINEAR ANNOTATION TERMINATOR',0xFFFC:'OBJECT REPLACEMENT CHARACTER',0x0640:'ARABIC TATWEEL 卡希达',0x180E:'MONGOLIAN VOWEL SEPARATOR',0x3164:'HANGUL FILLER 谚文填充',0x115F:'HANGUL CHOSEONG FILLER',0x1160:'HANGUL JUNGSEONG FILLER'};
  if(N[cp])return N[cp];
  if(cp>=0xFE00&&cp<=0xFE0F)return'VS-'+(cp-0xFE00+1);
  if(cp>=0xE0100&&cp<=0xE01EF)return'VS-'+(cp-0xE0100+17);
  if(cp===0xE0001)return'LANGUAGE TAG';
  if(cp>=0xE0020&&cp<=0xE007F)return'TAG '+(cp-0xE0020+32).toString(16).toUpperCase();
  return'U+'+cp.toString(16).toUpperCase();
}
function es(s){return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')}
let LI=[],FC=null;
function uDet(){
  const raw=document.getElementById('uI').value;
  if(!raw){document.getElementById('uS').innerHTML='';document.getElementById('uH').innerHTML='';document.getElementById('uC').innerHTML='';document.getElementById('uL').innerHTML='<div class="empty">请粘贴文本后点击检测</div>';return}
  const ch=[...raw],iss=[];const ct={[C1]:0,[C2]:0,[C3]:0,[C4]:0,[C5]:0,[C6]:0};
  for(let i=0;i<ch.length;i++){const cp=ch[i].codePointAt(0);const info=cls(cp);if(info){const nm=gn(cp);const sg=LA[cp]?LA[cp][1]:null;const rp=LA[cp]?LA[cp][0]:null;iss.push({p:i,cp,c:ch[i],info,nm,sg,rp});ct[info.c]++}}
  LI=iss;FC=null;const T=iss.length;
  document.getElementById('uS').innerHTML=`<div class="stats"><div class="sc ${T?'w':'ok'}"><div class="n">${T}</div><div class="l">可疑</div></div><div class="sc i"><div class="n">${ch.length}</div><div class="l">总字符</div></div>${[C1,C2,C3,C4,C5,C6].map(c=>`<div class="sc ${ct[c]?'w':'ok'}"><div class="n">${ct[c]}</div><div class="l">${CN[c]}</div></div>`).join('')}</div>`;
  const iS=new Set(iss.map(x=>x.p));let h='';
  for(let i=0;i<ch.length;i++){const cp=ch[i].codePointAt(0);let d=cp===10?'↵':cp===9?'⇥':es(ch[i]);
  if(iS.has(i)){const it=iss.find(x=>x.p===i);const inv=ZW.has(cp)||cp===0xFEFF||DR.has(cp)||inR(cp,VS)||inR(cp,TG)||FL.has(cp)||cp===SH;const dp=inv?'⏐':d;
  h+=`<span class="hw ${it.info.c}" data-i="${i}" data-info="U+${cp.toString(16).toUpperCase().padStart(4,'0')} ${it.nm}${it.sg?' | '+it.sg:''}">${dp}</span>`}else h+=d}
  document.getElementById('uH').innerHTML=T?`<div class="st">高亮预览</div><div class="hb">${h}</div>`:'';
  const uc=[...new Set(iss.map(x=>x.info.c))];let cH='<div class="ct">';cH+=`<span class="a" onclick="uFl(null,this)">全部(${T})</span>`;
  for(const c of uc)cH+=`<span onclick="uFl('${c}',this)">${CN[c]}(${ct[c]})</span>`;cH+='</div>';
  document.getElementById('uC').innerHTML=cH;rL(iss);
}
function rL(items){
  if(!items.length){document.getElementById('uL').innerHTML='<div class="empty" style="color:#2e7d32">✅ 无可疑字符</div>';return}
  let h=`<div class="st">详情(${items.length}项)</div>`;
  for(const it of items){const inv=ZW.has(it.cp)||it.cp===0xFEFF||DR.has(it.cp)||inR(it.cp,VS)||inR(it.cp,TG)||FL.has(it.cp)||it.cp===SH;const dp=inv?'⏐':es(it.c);const hx='U+'+it.cp.toString(16).toUpperCase().padStart(4,'0');
  h+=`<div class="ci"><span class="cb" style="background:${CC[it.info.c]}">${it.info.l}</span><span style="font-size:16px;min-width:20px;text-align:center;font-family:monospace">${dp}</span><span style="font-family:monospace;color:#555;font-size:11px">${hx}</span><span style="color:#333;font-size:11px;font-weight:600">${it.nm}</span>${it.sg?`<span style="color:#e65100;font-size:10px">⚠${it.sg}</span>`:''}<span style="color:#aaa;font-size:10px;margin-left:auto">位${it.p}</span></div>`}
  document.getElementById('uL').innerHTML=h;
}
function uFl(c,el){FC=c;document.querySelectorAll('#ud .ct span').forEach(s=>s.classList.remove('a'));el.classList.add('a');rL(c?LI.filter(x=>x.info.c===c):LI)}
